{
  "name": "orbit-workspace",
  "version": "0.1.2-beta",
  "private": true,
  "description": "Orbit P2P Chat — Workspace Root",
  "scripts": {
    "start": "cd desktop && electron .",
    "desktop:start": "cd desktop && electron .",
    "desktop:build:win": "cd desktop && electron-builder --win",
    "desktop:build:mac": "cd desktop && electron-builder --mac",
    "desktop:build:linux": "cd desktop && electron-builder --linux",
    "mobile:sync": "cd mobile && npm run shared:sync && npx cap sync android",
    "mobile:build": "cd mobile && powershell -File build-android.ps1",
    "mobile:open": "cd mobile && npx cap open android"
  }
}
