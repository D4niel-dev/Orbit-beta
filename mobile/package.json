{
  "name": "orbit-mobile",
  "version": "0.1.5-beta",
  "private": true,
  "description": "Orbit P2P Chat — Android App",
  "main": "src/index.html",
  "scripts": {
    "shared:sync": "node -e \"const fs=require('fs');const p=require('path');function c(s,d){fs.mkdirSync(d,{recursive:true});fs.readdirSync(s).forEach(f=>{const sp=p.join(s,f),dp=p.join(d,f);fs.statSync(sp).isDirectory()?c(sp,dp):fs.copyFileSync(sp,dp)})};c(p.resolve(__dirname,'..','shared'),p.resolve(__dirname,'src','shared'))\"",
    "cap:sync": "npm run shared:sync && npx cap sync android",
    "cap:build": "npm run shared:sync && npx cap build android",
    "cap:open": "npm run shared:sync && npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/filesystem": "^8.0.0",
    "@capacitor/local-notifications": "^8.2.0",
    "emoji-picker-element": "^1.29.1",
    "lucide": "^1.17.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.4"
  }
}
